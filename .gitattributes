# Normalize text files to LF in the repository and working tree.
# This reduces CRLF/LF noise on Windows while keeping binary assets untouched.
* text=auto eol=lf

# Common Unity and code text assets.
*.cs text eol=lf diff=csharp
*.shader text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.inputactions text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.scenetemplate text eol=lf

# Windows command scripts should stay CRLF-friendly.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.psd binary
*.bmp binary
*.ico binary
*.ttf binary
*.otf binary
*.wav binary
*.mp3 binary
*.ogg binary
*.fbx binary
*.dll binary
*.exe binary
*.zip binary
